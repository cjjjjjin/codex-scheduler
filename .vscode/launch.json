{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: FastAPI",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/backend/.venv/bin/python",
      "module": "uvicorn",
      "cwd": "${workspaceFolder}/backend",
      "args": [
        "app.main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8000"
      ],
      "jinja": false,
      "console": "integratedTerminal"
    },
    {
      "name": "Backend: FastAPI (Reload)",
      "type": "node-terminal",
      "request": "launch",
      "command": "${workspaceFolder}/backend/.venv/bin/python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
      "cwd": "${workspaceFolder}/backend"
    },
    {
      "name": "Frontend: Vite Dev Server",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev -- --host 0.0.0.0",
      "cwd": "${workspaceFolder}/frontend"
    },
    {
      "name": "Frontend: Chrome",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://192.168.0.14:5173",
      "webRoot": "${workspaceFolder}/frontend/src"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack",
      "configurations": [
        "Backend: FastAPI",
        "Frontend: Vite Dev Server",
        "Frontend: Chrome"
      ],
      "stopAll": true
    }
  ]
}
