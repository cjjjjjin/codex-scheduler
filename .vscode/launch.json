{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: Express",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/backend",
      "program": "${workspaceFolder}/backend/dist/server.js",
      "preLaunchTask": "backend: build",
      "console": "integratedTerminal",
      "sourceMaps": true,
      "outFiles": [
        "${workspaceFolder}/backend/dist/**/*.js"
      ],
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "name": "Backend: Express (Build/Run)",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "PORT": "8000"
      }
    },
    {
      "name": "Frontend: Vite Dev Server",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev -- --host 0.0.0.0",
      "cwd": "${workspaceFolder}/frontend"
    },
    {
      "name": "Frontend: Chrome",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://192.168.0.14:5173",
      "webRoot": "${workspaceFolder}/frontend/src"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack",
      "configurations": [
        "Backend: Express",
        "Frontend: Vite Dev Server",
        "Frontend: Chrome"
      ],
      "stopAll": true
    }
  ]
}
